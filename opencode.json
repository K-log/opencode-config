{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "rules.md"
  ],
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "snapshot": false,
  "compaction": {
    "reserved": 20000
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "default_agent": "plan",
  "permission": {
    "bash": {
      "*": "ask",
      "npx tsx --noEmit *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "git log *": "allow",
      "git status *": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "head *": "allow",
          "grep *": "allow",
          "tail *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "cat *": "allow"
        }
      },
      "options": {}
    },
    "plan-feature-analysis": {
      "model": "small_model",
      "options": {},
      "permission": {}
    },
    "plan-feature-research": {
      "model": "small_model",
      "options": {},
      "permission": {}
    }
  },
  "formatter": {
    "prettier-markdown": {
      "command": [
        "npx",
        "-y",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ],
      "environment": {
        "NODE_ENV": "production"
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "microsoft/playwright-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}