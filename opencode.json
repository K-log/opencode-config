{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "snapshot": false,
  "compaction": {
    "reserved": 20000
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "default_agent": "plan",
  "permission": {
    "bash": {
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "type *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "sed -n *": "allow",
      "jq *": "allow",
      "node --version": "allow",
      "npm --version": "allow",
      "bun --version": "allow"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "rm *": "deny",
          "rm -rf *": "deny",
          "rm -f *": "deny",
          "rmdir *": "deny",
          "mkfs *": "deny",
          "dd *": "deny",
          "chmod -R *": "deny",
          "chown -R *": "deny",
          "git clean *": "deny",
          "git checkout -- *": "deny",
          "git reset --hard*": "deny",
          "git push --force*": "deny",
          "git push -f *": "deny",
          "truncate *": "deny",
          "shred *": "deny",
          "*": "allow"
        }
      },
      "options": {}
    },
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "head *": "allow",
          "grep *": "allow",
          "tail *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "cat *": "allow"
        }
      },
      "options": {}
    },
    "parallelize-build": {
      "model": "github-copilot/gpt-5.4-nano"
    },
    "plan-feature-tests": {
      "model": "github-copilot/gpt-5.4-nano"
    },
    "parallelize-task": {
      "model": "github-copilot/gpt-5.4-nano"
    }
  },
  "formatter": {
    "prettier-markdown": {
      "command": [
        "npx",
        "-y",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ],
      "environment": {
        "NODE_ENV": "production"
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  }
}
