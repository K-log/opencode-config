{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "rules.md"
  ],
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "snapshot": false,
  "compaction": {
    "reserved": 20000
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "default_agent": "plan",
  "permission": {},
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5.3-codex",
      "rm *": "deny",
      "rm -rf *": "deny",
      "rm -f *": "deny",
      "rmdir *": "deny",
      "mkfs *": "deny",
      "dd *": "deny",
      "chmod -R *": "deny",
      "chown -R *": "deny",
      "git clean *": "deny",
      "git checkout -- *": "deny",
      "git reset --hard*": "deny",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "truncate *": "deny",
      "shred *": "deny",
      "*": "allow"
    },
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "head *": "allow",
          "grep *": "allow",
          "tail *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "cat *": "allow"
        }
      }
    },
    "ask": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "build-parallelizer": {
      "model": "github-copilot/gpt-5-mini"
    },
    "code-reviewer": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "plan-feature-analysis": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "plan-feature-research": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "plan-feature-tests": {
      "model": "github-copilot/gpt-5-mini"
    },
    "regression-checker": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "task-parallelizer": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "formatter": {
    "prettier-markdown": {
      "command": [
        "npx",
        "-y",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ],
      "environment": {
        "NODE_ENV": "production"
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  }
}
